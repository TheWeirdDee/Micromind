# Get FREE at https://console.groq.com (no credit card needed)
GROQ_API_KEY=gsk_your_key_here

# Fill after deploying smart contract
CONTRACT_ADDRESS=0x_your_contract_address

# Your deployer wallet private key (for agent wallet — create new one)
PRIVATE_KEY=0x_your_private_key

# OPTIONAL: Get FREE at https://upstash.com
# Without these, app uses in-memory storage (data lost on restart)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# From https://8004.xyz (required for AI Agent prize track)
AGENT_8004_ID=

# From https://self.xyz (required for AI Agent prize track)
SELF_AGENT_ID=

# true for Alfajores testnet, false for Celo mainnet
IS_TESTNET=true

PORT=3001
